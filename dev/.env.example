TELEGRAM_BOT_TOKEN=
# Private id from @userinfobot, or group id (negative, e.g. -100123...).
# Multiple chats: comma-separated (group + your DM).
TELEGRAM_CHAT_ID=

# Optional – usually auto-fetched (vinted-api style)
# Chrome: Application → Cookies → _vinted_de_session
VINTED_SESSION_COOKIE=

VINTED_HOST=www.vinted.de
VINTED_LOCALE=de-DE

# Optional proxy (same as npm VINTED_API_HTTPS_PROXY)
VINTED_PROXY=

SERPAPI_KEY=
# Seconds between full scan cycles (all targets). 20–35 is a good balance.
POLL_MIN_SECONDS=25
POLL_MAX_SECONDS=40

# Sniper platforms (comma-separated): vinted, kleinanzeigen, ebay
SNIPER_PLATFORMS=vinted,kleinanzeigen,ebay
# Local DanielWTE/ebay-kleinanzeigen-api (run start_kleinanzeigen_api.bat)
KLEINANZEIGEN_API_URL=http://127.0.0.1:8000
EBAY_HOST=www.ebay.de
